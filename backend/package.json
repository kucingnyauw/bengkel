{
  "name": "g-speed-backend",
  "version": "1.0.0",
  "description": "Backend service for G-Speed - Bengkel Motor Spesialis Vespa. Melayani servis, sparepart, dan perawatan Vespa",
  "author": "G-Speed",
  "license": "UNLICENSED",
  "type": "module",
  "main": "src/main.js",
  "imports": {
    "#app/*": "./src/application/*",
    "#controller/*": "./src/controller/*",
    "#service/*": "./src/service/*",
    "#routes/*": "./src/routes/*",
    "#middleware/*": "./src/middleware/*",
    "#shared/*": "./src/shared/*",
    "#lib/*": "./src/lib/*",
    "#dtos/*": "./src/dtos/*",
    "#validation/*": "./src/validation/*",
    "#config/*": "./src/config/*",
    "#repository/*": "./src/repository/*"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "scripts": {
    "dev": "nodemon src/main.js",
    "build": "prisma generate",
    "start": "node src/main.js",
    "start:prod": "NODE_ENV=production node src/main.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:pull": "prisma db pull",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.104.0",
    "@upstash/redis": "^1.37.0",
    "axios": "^1.15.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "joi": "^18.1.2",
    "midtrans-client": "^1.4.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prisma": "^5.22.0"
  }
}